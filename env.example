# Copia este archivo a .env y pon tus valores reales.
# El .env NUNCA se sube a GitHub (está en .gitignore).

# URL de la base de datos (la que te pasó Poyo, de Railway)
DATABASE_URL=postgresql://usuario:password@host.proxy.rlwy.net:PUERTO/railway

# (Opcional) API key de Google Books para evitar límites de cuota
GOOGLE_BOOKS_API_KEY=
